# ── CyberAgent: Multi-Agent PentestAI & Mitigation Platform ──────────────────
# Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env to git.

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MAIN_MODEL=deepseek-r1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
# Context window (tokens) — 8192 is safe for 8B on 23GB RAM
OLLAMA_NUM_CTX=8192
# Threads to use for inference (leave 2 free for OS)
OLLAMA_NUM_THREADS=14

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./knowledge_base/chroma_db
CHROMA_COLLECTION_EXPLOITDB=exploitdb
CHROMA_COLLECTION_MITRE=mitre_attack
CHROMA_COLLECTION_GTFOBINS=gtfobins

# ── Mission State ─────────────────────────────────────────────────────────────
MISSION_STATE_FILE=./logs/mission_state.json
REPORTS_DIR=./reports

# ── Pentest Scope (set per engagement) ───────────────────────────────────────
TARGET_DOMAIN=
TARGET_AUTHORIZED=false   # MUST be set to true before any active scan

# ── Phase 2: Ansible (leave empty for Phase 1) ────────────────────────────────
ANSIBLE_CONTROLLER_URL=
ANSIBLE_TOKEN=
ADMIN_NOTIFICATION_EMAIL=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/cyberagent.log
